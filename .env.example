# Groq API - get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LinkedIn OAuth access token - see LINKEDIN_SETUP.md for how to get this
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Google Sheets service account credentials (entire JSON as a single line)
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Sheet ID - the long ID in the sheet URL
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
